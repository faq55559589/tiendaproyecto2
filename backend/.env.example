PORT=3000
NODE_ENV=development
JWT_SECRET=reemplazar_por_secreto_largo_y_unico
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:8000/frontend
# Lista separada por coma. En produccion no puede quedar vacio ni usar localhost.
CORS_ORIGINS=http://localhost:8000,http://localhost:5500,http://127.0.0.1:5500
BACKEND_URL=http://localhost:3000
# Para probar webhook local de Mercado Pago con ngrok, reemplaza temporalmente BACKEND_URL por tu URL publica.
SQLITE_DB_PATH=
UPLOADS_DIR=

EMAIL_FROM=info@golazostore.com
# En produccion, si EMAIL_REQUIRED=true, debes configurar BREVO_API_KEY o SMTP_* o EMAIL_USER/EMAIL_PASS.
EMAIL_REQUIRED=false

# Opcion SMTP generica
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Opcion Gmail
EMAIL_USER=
EMAIL_PASS=

# Pedidos manuales por Instagram
INSTAGRAM_ORDER_EXPIRATION_HOURS=12

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_TOKEN=
MP_ORDER_EXPIRATION_MINUTES=30
